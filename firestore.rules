rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == "admin";
    }

    match /members/{memberId} {
      allow read: if isSignedIn() && (request.auth.uid == memberId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == memberId || isAdmin());
      allow create: if isSignedIn();
      allow delete: if false;
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
        (resource.data.memberId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow delete: if isSignedIn() &&
        (resource.data.memberId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    match /plans/{memberId} {
      allow read: if isSignedIn() && (request.auth.uid == memberId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == memberId;
    }

    // Churn scores are written only by the Python script (using the Admin SDK,
    // which bypasses these rules entirely) - so from the browser's perspective,
    // this data is read-only, and only admins can see it.
    match /churnScores/{memberId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
